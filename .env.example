# ArbiSignal.AI 수집기 환경 변수
# 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요
# .env 는 절대 커밋하지 마세요 (hook이 자동 차단)

# 대상 사이트 (Cloudflare Quick Tunnel URL — 바뀌면 여기서만 수정)
ARBI_BASE_URL=https://number-apnic-coordination-projected.trycloudflare.com

# 본인 계정 (로그인 세션 자동화용 — .auth/storage_state.json 생성 후 불필요)
ARBI_EMAIL=
ARBI_PASSWORD=

# 수집기 식별 (User-Agent 에 포함, 운영자 연락 채널)
CONTACT_EMAIL=jnl240205@gmail.com

# 일일 요청 예산 (초과 시 hard stop)
DAILY_REQUEST_BUDGET=5000

# 요청 간격 (초, 기본 1.5)
REQUEST_INTERVAL_SEC=1.5

# 로그 레벨 (DEBUG / INFO / WARNING)
LOG_LEVEL=INFO

# ────────────────────────────────────────────────────────────
# sajugen (사주풀이 PDF 생성기) — LLM 윤문(선택)
# 키를 비워두면 자동으로 룰 원문 폴백 = 비용 0, 동작 동일.
# 채우면 23개 섹션 문장을 Haiku 모델로 표현만 윤문(사실 슬롯 불변).
# .env 는 .gitignore + block-env-commit 훅으로 커밋 차단됨.
ANTHROPIC_API_KEY=
