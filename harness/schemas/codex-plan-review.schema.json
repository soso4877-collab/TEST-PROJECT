{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sajugen.local/schemas/codex-plan-review.schema.json",
  "title": "Codex Plan Review (Phase 2A, PLAN_VERDICT)",
  "description": "Codex가 읽기 전용으로 Claude 계획을 검토한 결과. 구현 후 diff 판정이 아니라 구현 전 계획 판정(PLAN_VERDICT)만 담는다.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "review_stage",
    "review_target",
    "checked_base_commit",
    "reviewed_task_sha256",
    "reviewed_plan_sha256",
    "verdict",
    "blockers",
    "warnings",
    "evidence",
    "allowed_files",
    "forbidden_files",
    "required_validations",
    "no_modification_performed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "codex_review"
    },
    "review_stage": {
      "const": "plan"
    },
    "review_target": {
      "const": "claude-plan.json"
    },
    "checked_base_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "reviewed_task_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "reviewed_plan_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "verdict": {
      "enum": ["APPROVE", "BLOCK"]
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_validations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "no_modification_performed": {
      "const": true
    }
  }
}
