<!doctype html><html lang="ko"><head><meta charset="utf-8">
<title>{{ title }}</title>
<style>
  /* 폰트 번들(SIL OFL). 본문·제목 = 나눔명조 R/B(금강산 레퍼런스와 동일 패밀리).
     나눔명조는 한자 글리프 0 → 한자는 스택 폴백 'SajuHanja'(Source Han Serif K)가 받음
     (부록 용어 병기·표지 장식 한정). 'SajuBrush'(나눔브러시)는 표지 표제·목차 헤더 전용.
     'Saju'(Pretendard, sans)는 목차 칩 등 보조에만. Chromium 서브셋 임베드. */
  @font-face{font-family:'SajuMyeongjo';font-weight:400;font-style:normal;
    src:url('{{ font_dir }}/NanumMyeongjo-Regular.ttf') format('truetype')}
  @font-face{font-family:'SajuMyeongjo';font-weight:700;font-style:normal;
    src:url('{{ font_dir }}/NanumMyeongjo-Bold.ttf') format('truetype')}
  @font-face{font-family:'SajuBrush';font-weight:400;font-style:normal;
    src:url('{{ font_dir }}/NanumBrushScript-Regular.ttf') format('truetype')}
  @font-face{font-family:'SajuHanja';font-weight:400;font-style:normal;
    src:url('{{ font_dir }}/SourceHanSerifK-Regular.otf') format('opentype')}
  @font-face{font-family:'Saju';font-weight:400;font-style:normal;
    src:url('{{ font_dir }}/Pretendard-Regular.woff2') format('woff2');
    unicode-range:U+0000-04FF,U+1100-11FF,U+2000-206F,U+3000-303F,U+3130-318F,U+AC00-D7A3,U+FF00-FFEF}
  @font-face{font-family:'Saju';font-weight:600;font-style:normal;
    src:url('{{ font_dir }}/Pretendard-SemiBold.woff2') format('woff2');
    unicode-range:U+0000-04FF,U+1100-11FF,U+2000-206F,U+3000-303F,U+3130-318F,U+AC00-D7A3,U+FF00-FFEF}

  :root{
    /* 절제된 색: 거의 무채색 잉크 + 옅은 골드 룰(비텍스트). 처리유창성=균일·차분. */
    --bg:#fffdf8; --panel:#f7f1e2; --line:#ddd3bb; --ink:#222630; --mut:#5b6675;
    --gold:#9a6f1e; --gold-ink:#7d5610;
    --fs:11.5pt;          /* 본문 기준(명조) */
    --lh:1.72;            /* 단문 호흡 본문 행간 — 문단 간격이 호흡을 담당 */
    --lh-tight:1.32;
    --ls:-0.003em;        /* 명조 한글 자간(거의 0) */
    --s1:4px;--s2:8px;--s3:12px;--s4:16px;--s5:24px;--s6:32px;--s7:48px;
    --maxw:148mm}
  *{box-sizing:border-box}
  @page{size:A4;margin:{{ page_margin_css }}}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);
    font-family:'SajuMyeongjo','SajuHanja','Saju',serif;
    line-height:var(--lh);font-size:var(--fs);letter-spacing:var(--ls);
    -webkit-print-color-adjust:exact;print-color-adjust:exact}

  /* 표지 — 영문 키커·기술메타 제거(docs/13). 제목 + 가는 룰 + 이름/입력일만. */
  .cover{height:245mm;display:flex;flex-direction:column;justify-content:center;
    align-items:center;text-align:center;page-break-after:always}
  .cover h1{font-size:30pt;font-weight:400;letter-spacing:.18em;line-height:1.3;margin:0}
  .cover .rule{width:48px;height:1px;background:var(--gold);margin:11mm 0}
  .cover .sub{color:var(--mut);font-size:12pt;white-space:pre-line;line-height:1.95;
    letter-spacing:var(--ls)}

  /* 목차 — 노동착시·정보격차 호기심·책 권위(docs/13) */
  .toc{page-break-after:always;padding:18mm 0 0}
  .toc .toc-head{font-size:18pt;font-weight:400;letter-spacing:.2em;text-align:center;
    margin:0 0 var(--s7);color:var(--ink)}
  .toc-row{display:flex;align-items:baseline;gap:var(--s4);
    padding:var(--s3) 0;border-bottom:1px solid var(--line);max-width:var(--maxw);margin:0 auto}
  .toc-no{font-family:'Saju',sans-serif;color:var(--gold-ink);font-size:.85em;
    letter-spacing:.1em;min-width:2.4em}
  .toc-name{font-size:1.05em;color:var(--ink)}

  /* 챕터 = 한 장(章). 새 페이지에서 시작, 제N장 라벨 + 제목(=h2 아웃라인 소스) + 가는 룰. */
  section.chapter{page-break-before:always;page-break-inside:auto}
  .cnum{font-family:'Saju',sans-serif;color:var(--gold-ink);font-size:10.5pt;
    letter-spacing:.32em;text-align:center;margin:14mm 0 0}
  h2.ctitle{font-size:23pt;font-weight:400;letter-spacing:.02em;line-height:var(--lh-tight);
    text-align:center;color:var(--ink);margin:5mm 0 0}
  .crule{width:52px;height:1px;background:var(--gold);margin:8mm auto var(--s7)}

  .subhead{font-size:1.28em;font-weight:400;color:var(--ink);
    line-height:1.4;margin:var(--s6) 0 var(--s3)}
  /* 본문 = 단문 호흡: 문단(<p>)별 분리 + 여백이 빈 줄 호흡을 담당.
     좌측정렬(ragged right) — 금강산 방식, justify 강제 줄간 늘임 제거. */
  .body{margin:0;max-width:var(--maxw);
    line-height:var(--lh);text-align:left;word-break:keep-all}
  .body p{white-space:pre-line;text-indent:0;margin:0 0 .95em;
    orphans:2;widows:2}
  .disclaimer{font-size:.86em;color:var(--mut);background:var(--panel);
    border:1px solid var(--line);border-radius:4px;padding:var(--s4);
    margin-top:var(--s6);line-height:1.7;letter-spacing:0;text-align:left}
  @media print{section{break-inside:auto}.cnum,h2.ctitle{break-after:avoid}
    .subhead{break-after:avoid}}
</style></head><body>

<div class="cover">
  <h1>사 주 풀 이</h1>
  <div class="rule"></div>
  <div class="sub">{{ cover_sub }}</div>
</div>

{# 목차 — 보이는 챕터(표지·목차 제외) 나열 #}
<div class="toc">
  <div class="toc-head">목 차</div>
  {% set ns = namespace(n=0) %}
  {% for s in sections %}{% if s.id not in ['cover','toc'] %}{% set ns.n = ns.n + 1 %}
  <div class="toc-row"><span class="toc-no">{% if s.id in ['appendix_terms','colophon'] %}·{% else %}제 {{ ns.n }} 장{% endif %}</span><span class="toc-name">{{ s.title }}</span></div>
  {% endif %}{% endfor %}
</div>

{% set cs = namespace(n=0) %}
{% for s in sections %}
{% if s.id not in ['cover','toc'] %}
{% if s.id not in ['appendix_terms','colophon'] %}{% set cs.n = cs.n + 1 %}{% endif %}
<section id="sec-{{ s.id }}" class="chapter">
  {% if s.id not in ['appendix_terms','colophon'] %}<div class="cnum">제 {{ cs.n }} 장</div>{% endif %}
  <h2 class="ctitle">{{ s.title }}</h2>
  <div class="crule"></div>
  <div class="body">{% for p in s.paragraphs %}<p>{{ p }}</p>{% endfor %}</div>
  {% if s.id == 'colophon' %}<div class="disclaimer">{{ disclaimer }}</div>{% endif %}
</section>
{% endif %}
{% endfor %}

</body></html>
