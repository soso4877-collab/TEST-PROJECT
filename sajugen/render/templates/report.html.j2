<!doctype html><html lang="ko"><head><meta charset="utf-8">
<title>{{ title }}</title>
<style>
  /* 폰트 번들(전부 SIL OFL — 임베드 허용 검증 완료, 2026-06-12 업그레이드).
     본문 'SajuBody' = 고운바탕 R/B(따뜻한 고전 바탕, 한글 11,172자).
     제목·표제 'SajuHead' = 본명조(Source Han Serif KR) Bold — 격조·한자 일체.
     한자 폴백 'SajuHanja' = 본명조 Regular(부록 병기·장식 한정).
     'Saju'(Pretendard, sans)는 목차 칩 등 보조에만. Chromium 서브셋 임베드. */
  @font-face{font-family:'SajuBody';font-weight:400;font-style:normal;
    src:url('{{ font_dir }}/GowunBatang-Regular.ttf') format('truetype')}
  @font-face{font-family:'SajuBody';font-weight:700;font-style:normal;
    src:url('{{ font_dir }}/GowunBatang-Bold.ttf') format('truetype')}
  @font-face{font-family:'SajuHead';font-weight:700;font-style:normal;
    src:url('{{ font_dir }}/SourceHanSerifKR-Bold.otf') format('opentype')}
  @font-face{font-family:'SajuHanja';font-weight:400;font-style:normal;
    src:url('{{ font_dir }}/SourceHanSerifK-Regular.otf') format('opentype')}
  @font-face{font-family:'Saju';font-weight:400;font-style:normal;
    src:url('{{ font_dir }}/Pretendard-Regular.woff2') format('woff2');
    unicode-range:U+0000-04FF,U+1100-11FF,U+2000-206F,U+3000-303F,U+3130-318F,U+AC00-D7A3,U+FF00-FFEF}
  @font-face{font-family:'Saju';font-weight:600;font-style:normal;
    src:url('{{ font_dir }}/Pretendard-SemiBold.woff2') format('woff2');
    unicode-range:U+0000-04FF,U+1100-11FF,U+2000-206F,U+3000-303F,U+3130-318F,U+AC00-D7A3,U+FF00-FFEF}

  :root{
    /* 절제된 색: 거의 무채색 잉크 + 옅은 골드 룰(비텍스트). 처리유창성=균일·차분. */
    --bg:#fffdf8; --panel:#f7f1e2; --line:#ddd3bb; --ink:#111111; --mut:#4a4438;
    --gold:#9a6f1e; --gold-ink:#7d5610; --injoo:#a23b2c;
    /* 본문 타이포(2026-06-12 운영자 지시·금강산 실측 15pt/행송 28pt 기반 상향):
       한글 본문 행간 권장 180~210% 범위 안. 잉크는 한지 위 과대비 피해 #111. */
    --fs:14.5pt;
    --lh:1.8;
    --lh-tight:1.32;
    --ls:0;
    --s1:4px;--s2:8px;--s3:12px;--s4:16px;--s5:24px;--s6:32px;--s7:48px;
    --maxw:148mm}
  *{box-sizing:border-box}
  @page{size:A4;margin:{{ page_margin_css }}}
  /* 배경은 PDF 후처리 언더레이(한지 텍스처) — 여기서 칠하면 텍스처를 가린다 */
  html,body{margin:0;padding:0;background:transparent;color:var(--ink);
    font-family:'SajuBody','SajuHanja','Saju',serif;
    line-height:var(--lh);font-size:var(--fs);letter-spacing:var(--ls);
    -webkit-print-color-adjust:exact;print-color-adjust:exact}

  /* 표지 — 금강산 구도: 상단 붓글씨 표제 + 이름, 중앙 이중 테두리 세로 표제 박스,
     하단 생년월일시. */
  .cover{height:245mm;display:flex;flex-direction:column;align-items:center;
    text-align:center;page-break-after:always;padding-top:26mm}
  /* 붓글씨(나눔브러시) 폐기 — '목차→목과'로 읽힐 만큼 흘림(운영자 지적 2026-06-12)
     → 금강산 방식: 명조 Bold 대형 + 넓은 자간(단정한 학문 톤) */
  .cover h1{font-family:'SajuHead','SajuBody',serif;font-size:34pt;font-weight:700;
    letter-spacing:.22em;line-height:1.3;margin:0}
  .cover .cover-name{font-size:13.5pt;color:var(--ink);margin:9mm 0 0;letter-spacing:.14em}
  .cover .cover-box{margin:24mm 0 0;border:1px solid #6b6353;padding:2.2mm}
  .cover .cover-box-in{border:1px solid #6b6353;padding:11mm 6.5mm}
  .cover .cover-vert{writing-mode:vertical-rl;text-orientation:upright;
    font-family:'SajuHead','SajuBody',serif;font-size:38pt;font-weight:700;line-height:1;
    letter-spacing:.5em;color:var(--ink)}
  .cover .cover-seal{margin:11mm 0 0}
  .cover .sub{color:var(--mut);font-size:11.5pt;white-space:pre-line;line-height:1.95;
    letter-spacing:var(--ls);margin-top:auto;padding-bottom:6mm}

  /* 목차 — 금강산 구도: 붓글씨 헤더 + 장 칩 + 대시 리더 + 챕터명 */
  .toc{page-break-after:always;padding:14mm 0 0}
  .toc .toc-head{font-family:'SajuHead','SajuBody',serif;font-size:24pt;
    font-weight:700;letter-spacing:.55em;text-indent:.55em;text-align:center;
    margin:0 0 4mm;color:var(--ink)}
  .toc .toc-rule{width:34mm;height:1px;background:var(--line);margin:0 auto var(--s7)}
  .toc-row{display:flex;align-items:center;gap:var(--s4);
    padding:var(--s3) 0;max-width:128mm;margin:0 auto}
  .toc-no{color:var(--injoo);font-size:.92em;letter-spacing:.28em;min-width:5.2em;
    text-align:justify;text-align-last:justify}
  .toc-dash{flex:0 0 16mm;border-bottom:1px solid #8d8268;height:0}
  .toc-name{font-size:1.06em;color:var(--ink);letter-spacing:.04em;
    word-break:keep-all;overflow-wrap:normal;line-break:strict}

  /* 챕터 = 한 장(章). 새 페이지에서 시작, 제N장 라벨 + 제목(=h2 아웃라인 소스) + 가는 룰. */
  section.chapter{page-break-before:always;page-break-inside:auto}
  .cnum{font-family:'Saju',sans-serif;color:var(--gold-ink);font-size:10.5pt;
    letter-spacing:.32em;text-align:center;margin:14mm 0 0}
  h2.ctitle{font-family:'SajuHead','SajuBody',serif;font-size:26pt;font-weight:700;
    letter-spacing:.02em;line-height:var(--lh-tight);word-break:keep-all;
    overflow-wrap:normal;line-break:strict;
    text-align:center;color:var(--ink);margin:5mm 0 0}
  /* 어미(魚尾) 모티프 — 전통 판식의 장 시작 장식(절제 차용, 인주색) */
  .crule{width:76px;margin:7mm auto var(--s7);display:block}

  .subhead{font-size:1.28em;font-weight:400;color:var(--ink);
    line-height:1.4;margin:var(--s6) 0 var(--s3)}
  /* 본문 = 단문 호흡: 문단(<p>)별 분리 + 여백이 빈 줄 호흡을 담당.
     좌측정렬(ragged right) — 금강산 방식, justify 강제 줄간 늘임 제거. */
  .body{margin:0;max-width:var(--maxw);
    line-height:var(--lh);text-align:left;word-break:keep-all}
  .body p{white-space:pre-line;text-indent:0;margin:0 0 .95em;
    orphans:4;widows:4}
  @media print{section{break-inside:auto}.cnum,h2.ctitle{break-after:avoid}
    .subhead{break-after:avoid}}
</style></head><body>

<div class="cover">
  <h1>{{ brand_title }}</h1>
  {% if cover_name %}<div class="cover-name">{{ cover_name }}</div>{% endif %}
  <div class="cover-box"><div class="cover-box-in"><div class="cover-vert">{{ brand_seal }}</div></div></div>
  <svg class="cover-seal" role="img" aria-label="낙관" width="46" height="46" viewBox="0 0 46 46">
    <rect x="1.5" y="1.5" width="43" height="43" rx="3" fill="#a23b2c" opacity="0.88"/>
    <text x="23" y="19.5" font-family="SajuHead" font-weight="700" font-size="15"
          fill="#f6f0e0" text-anchor="middle">{{ brand_seal[:2] }}</text>
    <text x="23" y="38.5" font-family="SajuHead" font-weight="700" font-size="15"
          fill="#f6f0e0" text-anchor="middle">{{ brand_seal[2:4] }}</text>
  </svg>
  <div class="sub">{{ cover_sub }}</div>
</div>

{# 목차 — 보이는 챕터(표지·목차 제외) 나열 #}
<div class="toc">
  <div class="toc-head">목차</div>
  <div class="toc-rule"></div>
  {% set ns = namespace(n=0) %}
  {% for s in sections %}{% if s.id not in ['cover','toc'] %}{% set ns.n = ns.n + 1 %}
  <div class="toc-row"><span class="toc-no">{% if s.id == 'appendix_terms' %}부록{% elif s.id == 'colophon' %}끝으로{% else %}제 {{ ns.n }} 장{% endif %}</span><span class="toc-dash"></span><span class="toc-name">{{ s.title.replace('부록 — ', '') if s.id == 'appendix_terms' else s.title }}</span></div>
  {% endif %}{% endfor %}
</div>

{% set cs = namespace(n=0) %}
{% for s in sections %}
{% if s.id not in ['cover','toc'] %}
{% if s.id not in ['appendix_terms','colophon'] %}{% set cs.n = cs.n + 1 %}{% endif %}
<section id="sec-{{ s.id }}" class="chapter">
  {% if s.id not in ['appendix_terms','colophon'] %}<div class="cnum">제 {{ cs.n }} 장</div>{% endif %}
  <h2 class="ctitle">{{ s.title }}</h2>
  <svg class="crule" role="img" aria-label="장식" width="76" height="10" viewBox="0 0 76 10">
    <line x1="0" y1="5" x2="29" y2="5" stroke="#a23b2c" stroke-width="0.9"/>
    <path d="M33 1 L43 1 L38 9 Z" fill="#a23b2c" opacity="0.88"/>
    <line x1="47" y1="5" x2="76" y2="5" stroke="#a23b2c" stroke-width="0.9"/>
  </svg>
  <div class="body">{% for p in s.paragraphs %}<p>{{ p }}</p>{% endfor %}</div>
</section>
{% endif %}
{% endfor %}

</body></html>
